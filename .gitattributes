# Text normalization
* text=auto
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.txt text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.py text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Large/binary artifacts (recommend Git LFS)
*.a filter=lfs diff=lfs merge=lfs -text
*.so filter=lfs diff=lfs merge=lfs -text
*.aar filter=lfs diff=lfs merge=lfs -text
*.apk filter=lfs diff=lfs merge=lfs -text
*.aab filter=lfs diff=lfs merge=lfs -text

# OpenCV vendored libs
opencv/native/3rdparty/libs/** filter=lfs diff=lfs merge=lfs -text
